{
  "name": "fleet-management-backend",
  "version": "1.0.0",
  "description": "Real-time backend for Fleet Management System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watch --detectOpenHandles",
    "test:coverage": "jest --coverage --detectOpenHandles --forceExit",
    "test:integration": "jest tests/integration.test.js --detectOpenHandles --forceExit",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "verify": "node scripts/verify-system.js",
    "health": "curl -s http://localhost:3000/health",
    "lint": "eslint . --ext .js --ignore-path .gitignore || true",
    "start:prod": "NODE_ENV=production node server.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "mongoose": "^7.5.0",
    "redis": "^4.6.7",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "joi": "^17.9.2",
    "express-rate-limit": "^6.8.1",
    "express-validator": "^7.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.6.2",
    "supertest": "^6.3.3",
    "@types/jest": "^29.5.3"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": ["fleet", "management", "real-time", "websocket", "gps"],
  "author": "Fleet Management Team",
  "license": "MIT"
}